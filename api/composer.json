{
	"name": "adx/adx-global-base-api",
	"description": "ADX-BASE-API — Premium Software Architecture by Rafael Peres",
	"license": "proprietary",
	"type": "project",
	"homepage": "https://rafaelperes.com/",
	"require": {
		"php": "^8.5",
		"codeigniter4/framework": "^4.7",
		"firebase/php-jwt": "^7.0",
		"ramsey/uuid": "^4.9"
	},
	"require-dev": {
		"fakerphp/faker": "^1.23",
		"mikey179/vfsstream": "^1.6",
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/",
			"Config\\": "app/Config/",
			"Tests\\": "tests/"
		},
		"exclude-from-classmap": [
			"**/Database/Migrations/**"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\Support\\": "tests/_support"
		}
	},
	"config": {
		"allow-plugins": {
			"php-http/discovery": true
		},
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true
	},
	"scripts": {
    "test": "vendor/bin/phpunit --no-coverage --testdox tests/unit",
    "test:report": [
      "vendor/bin/phpunit --no-coverage --stderr --log-junit tests/report/results.xml tests/unit || (exit 0)",
      "php tests/utils/generate_plus.php"
    ]
  }
}